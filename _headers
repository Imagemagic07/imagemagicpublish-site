# Cloudflare Pages — HTTP headers
# Security headers on everything
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# Long-cache fingerprinted static assets (images/fonts don't change)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# CSS/JS are versioned via ?v=N in the HTML, so they can cache long too
/styles.css
  Cache-Control: public, max-age=31536000, immutable
/app.js
  Cache-Control: public, max-age=31536000, immutable
/i18n.js
  Cache-Control: public, max-age=31536000, immutable

# HTML should always revalidate so content updates go live immediately
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# ---------------------------------------------------------------------------
# CONTENT SECURITY POLICY (enable AFTER integrations are wired).
# Uncomment and adjust once you know exactly which 3rd-party domains you use
# (Google Analytics, Meta Pixel, Turnstile, MailerLite, Calendly). A wrong CSP
# silently breaks things, so it's left off until the integrations are final.
